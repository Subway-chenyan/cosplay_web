# Django 配置
# 生成强随机 SECRET_KEY：python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
DJANGO_ENV=production

# 数据库配置
DB_HOST=localhost
DB_PORT=5433
DB_NAME=cosplay_db
DB_USER=cosplay_user
DB_PASSWORD=change-me
DB_CONN_MAX_AGE=60

# text2sql 智能检索专用【只读】数据库账号（生产环境强烈建议配置）
# CREATE ROLE text2sql_ro LOGIN PASSWORD '...';
# GRANT CONNECT ON DATABASE cosplay_db TO text2sql_ro;
# GRANT USAGE ON SCHEMA public TO text2sql_ro;
# GRANT SELECT ON ALL TABLES IN SCHEMA public TO text2sql_ro;
TEXT2SQL_DB_USER=
TEXT2SQL_DB_PASSWORD=

# Redis 配置
REDIS_URL=redis://localhost:6379/0

# 允许的主机
ALLOWED_HOSTS=data.cosdrama.cn,www.cosdrama.cn

# CORS 配置
CORS_ALLOWED_ORIGINS=https://www.cosdrama.cn,https://cosdrama.cn

# 静态文件配置
STATIC_URL=/static/
MEDIA_URL=/media/
STATIC_ROOT=staticfiles
MEDIA_ROOT=media

# Celery 配置（可选）
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# 日志配置
LOG_LEVEL=INFO

# Cloudflare R2 配置（从 Cloudflare 控制台获取，切勿提交真实值）
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT_URL=
R2_CUSTOM_DOMAIN=

# DeepSeek / LLM API Key（切勿提交真实值）
DEEPSEEK_API_KEY=
